{
  "name": "pitch-twin",
  "version": "1.0.0",
  "description": "AI-powered sales pitch preparation tool",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start"
  },
  "keywords": [
    "sales",
    "pitch",
    "ai",
    "anthropic",
    "firecrawl",
    "elevenlabs"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ]
}
